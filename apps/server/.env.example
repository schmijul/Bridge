PORT=4000
CORS_ORIGIN=http://localhost:5173
AUTH_MODE=local
STORE_DRIVER=postgres
DATABASE_URL=postgres://bridge:bridge@localhost:5432/bridge
RUN_MIGRATIONS_ON_BOOT=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
