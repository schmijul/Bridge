{
  "name": "@bridge/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist && ../../scripts/build-meta.sh dist/build-meta.json",
    "start": "node dist/apps/server/src/index.js",
    "db:migrate": "tsx src/migrate.ts",
    "test": "tsx --test src/*.test.ts && tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bridge/shared": "0.1.0",
    "@fastify/cors": "^10.1.0",
    "fastify": "^5.2.1",
    "pg": "^8.16.3",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.3"
  }
}
