{
  "name": "@bridge/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bridge desktop shell built on Electron.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "electron dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts && tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "electron": "41.1.1",
    "tsx": "^4.19.3"
  }
}
